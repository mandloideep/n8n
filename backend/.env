ENV=development
DATABASE_URL=sqlite:///./test.db
API_PREFIX=/api
DEBUG=True

# Local-only dev key. Replace with `openssl rand -hex 32` if you want a fresh one.
# DO NOT use this value in production — set SECRET_KEY in Dokploy instead.
SECRET_KEY=dev_only_secret_replace_me_locally_with_openssl_rand_hex_32_xx

ALLOWED_ORIGINS=https://localhost:3000,https://localhost:5173,http://127.0.0.1:5173,http://localhost:8001,http://localhost:8080

OPENAI_API_KEY=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
