# Copy to backend/.env and fill in the values for local dev.
# In production, set these in the Dokploy app's Environment tab — NOT in a file.

# Runtime mode: "development" or "production".
# When "production": uvicorn reload is OFF, /docs and /redoc are hidden,
# cookies are issued with Secure=True.
ENV=development

# Reserved for future router prefixing. Not currently used by the code —
# routers are mounted at /auth, /credential, /webh, /workf without a prefix.
API_PREFIX=/api

# Database connection. The app uses SQLAlchemy's async engine, so the URL
# must reference an async driver:
#   Dev:   sqlite+aiosqlite:///./test.db   (aiosqlite ships in dev deps)
#   Prod:  postgresql+psycopg://USER:PASS@HOST/DB?sslmode=require
# (psycopg3 is async-native — no separate driver string needed for Postgres.)
DATABASE_URL=sqlite+aiosqlite:///./test.db

# JWT signing key — MUST be at least 32 characters.
# Generate with: openssl rand -hex 32
SECRET_KEY=replace_me_with_openssl_rand_hex_32_at_least_32_chars_long_xx

# Fernet key for encrypting credentials at rest (Telegram tokens, etc).
# Required. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Rotating this value invalidates all stored credentials — they will need to be re-entered.
CREDENTIALS_ENCRYPTION_KEY=

# CORS allowed origins (comma-separated). Must be non-empty and must NOT include '*'.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:8001

# Optional. Required only if you actually use OpenAI features.
OPENAI_API_KEY=

# Telegram bot credentials, required only if a workflow uses the Telegram node.
# IMPORTANT: any token previously committed to this repo is compromised —
# rotate it via @BotFather (/revoke + /token) before pasting a value here.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Where the built frontend SPA is mounted. Set automatically in the Docker image.
# Leave unset for local dev.
# STATIC_DIR=static
