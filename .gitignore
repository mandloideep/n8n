# Env files (per-environment secrets — never commit)
.env
.env.local
.env.*.local
backend/.env
backend/.env.local
# Keep frontend/.env.production tracked (no secrets, build config only)
frontend/.env
frontend/.env.local

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.coverage
htmlcov/

# SQLite (dev only)
*.db
*.sqlite
*.sqlite3

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output
dist/
build/

# TypeScript incremental build info
*.tsbuildinfo

# Test coverage
coverage/

# OS junk
.DS_Store
Thumbs.db

# IDE
.vscode/*
!.vscode/extensions.json
.idea/

# Local plan / scratch
.claude/
